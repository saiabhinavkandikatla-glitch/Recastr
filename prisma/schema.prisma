generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                   @id @default(cuid())
  supabaseId             String                   @unique
  email                  String                   @unique
  name                   String?
  avatarUrl              String?
  creatorType            String?
  tonePref               String                   @default("casual")
  platforms              String[]
  role                   String                   @default("member")
  plan                   String                   @default("free")
  planExpiresAt          DateTime?
  notifyContentReady     Boolean                  @default(true)
  notifyWeeklyDigest     Boolean                  @default(true)
  notifyScheduleReminder Boolean                  @default(true)
  notifyMarketing        Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  projects               Project[]
  scheduledPosts         ScheduledPost[]
  brandVoices            BrandVoice[]
  usageEvents            UsageEvent[]
  credits                UserCredit?
  jobRecords             JobRecord[]
  ownedOrganizations     Organization[]           @relation("OrganizationOwner")
  memberships            OrganizationMembership[]
  auditLogs              AuditLog[]
  billingSubscriptions   BillingSubscription[]
  billingInvoices        BillingInvoice[]
  billingEvents          BillingEvent[]
  platformCredentials    UserPlatformCredential[]
  postingPreference      UserPostingPreference?

  @@index([plan, createdAt])
}

model Project {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  title          String
  sourceUrl      String?
  sourceText     String?       @db.Text
  sourceType     String        @default("text")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  thumbnailUrl   String?
  transcript     String?       @db.Text
  summary        Json?
  duration       Int?
  wordCount      Int?
  hooks          Hook[]
  contents       Content[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([sourceType])
}

model Organization {
  id          String                   @id @default(cuid())
  name        String
  slug        String                   @unique
  ownerId     String
  owner       User                     @relation("OrganizationOwner", fields: [ownerId], references: [id])
  projects    Project[]
  memberships OrganizationMembership[]
  auditLogs   AuditLog[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([ownerId])
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId, role])
}

model Hook {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id])
  text       String    @db.Text
  hookType   String
  reachScore Float
  contents   Content[]
  createdAt  DateTime  @default(now())

  @@index([projectId, reachScore])
}

model Content {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id])
  hookId        String?
  hook          Hook?          @relation(fields: [hookId], references: [id])
  platform      String
  contentType   String
  body          String         @db.Text
  originalBody  String         @db.Text
  tone          String
  approved      Boolean        @default(false)
  order         Int            @default(0)
  scheduledPost ScheduledPost?
  createdAt     DateTime       @default(now())

  @@index([projectId, platform, order])
  @@index([approved])
}

model ScheduledPost {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  contentId   String    @unique
  content     Content   @relation(fields: [contentId], references: [id])
  platform    String
  scheduledAt DateTime
  postingMethod String    @default("email_reminder")
  timezone    String      @default("Asia/Kolkata")
  verificationRequired Boolean @default(false)
  verifiedByUser Boolean  @default(false)
  verifiedAt   DateTime?
  platformPostId String?
  status      String    @default("pending")
  publishedAt DateTime?
  failReason  String?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  history      PostHistory[]

  @@index([userId, status, scheduledAt])
  @@index([userId, postingMethod, status, scheduledAt])
}

model PostHistory {
  id              String        @id @default(cuid())
  scheduledPostId String
  scheduledPost   ScheduledPost @relation(fields: [scheduledPostId], references: [id], onDelete: Cascade)
  platform        String
  status          String
  engagementMetrics Json?
  postedAt        DateTime?
  errorDetails    String?
  createdAt       DateTime      @default(now())

  @@index([scheduledPostId, createdAt])
  @@index([platform, status, createdAt])
}

model UserPlatformCredential {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       String
  accessToken    String    @db.Text
  refreshToken   String?   @db.Text
  apiKey         String?   @db.Text
  apiSecret      String?   @db.Text
  handle         String?
  platformUserId String?
  isActive       Boolean   @default(true)
  connectedAt    DateTime  @default(now())
  expiresAt      DateTime?
  lastTestedAt   DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([userId, isActive])
}

model UserPostingPreference {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultPostingMethod     String   @default("email_reminder")
  timezone                 String   @default("Asia/Kolkata")
  postVerificationRequired Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model BrandVoice {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  name            String
  toneDescriptors String[]
  bannedWords     String[]
  samplePosts     String[]
  targetAudience  String
  contentPillars  String[]
  createdAt       DateTime @default(now())

  @@index([userId])
}

model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, eventType, createdAt])
}

model BillingSubscription {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               String
  interval           String           @default("monthly")
  status             String           @default("pending")
  razorpayOrderId    String?          @unique
  razorpayPaymentId  String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  metadata           Json?
  invoices           BillingInvoice[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([userId, status, currentPeriodEnd])
  @@index([plan, status])
}

model BillingInvoice {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId    String?
  subscription      BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan              String
  interval          String               @default("monthly")
  amount            Int
  currency          String               @default("INR")
  status            String               @default("created")
  receipt           String               @unique
  razorpayOrderId   String?              @unique
  razorpayPaymentId String?
  razorpaySignature String?
  paidAt            DateTime?
  failedAt          DateTime?
  failReason        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([userId, status, createdAt])
  @@index([razorpayPaymentId])
}

model BillingEvent {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventId     String    @unique
  eventType   String
  processed   Boolean   @default(false)
  payload     Json?
  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@index([userId, receivedAt])
  @@index([eventType, processed])
}

model UserCredit {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  credits   Int       @default(15)
  used      Int       @default(0)
  resetAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, credits])
}

model JobRecord {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  type         String
  status       String   @default("pending")
  progress     Int      @default(0)
  payload      Json?
  result       Json?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, status, createdAt])
  @@index([type, status])
}

model AuditLog {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  ipHash         String?
  userAgent      String?
  createdAt      DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}
